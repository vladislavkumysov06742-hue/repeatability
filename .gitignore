cat > .gitignore << 'EOF'
# Большие папки с данными (не для Git)
all/01KP/
all/cleaned/

# Мусор в output (но stats оставляем)
output/D:repeatabilityplots/

# Виртуальные окружения и кэш
venv/
__pycache__/
*.pyc
*.pyo

# Логи, временные отчёты, SLURM-логи
slurm_logs/
text_reports/
*.log
*.out
*.dump
*.data

# Архивы
*.tar.gz
*.tgz
*.zip
*.7z

# Системные временные файлы
.DS_Store
*.swp
*.tmp
*.bak
*.orig

# Прочее
tree.txt
EOF

# Исключаем виртуальную среду cleaning-env (она огромная)
output/cleaning-env/

# Дополнительно, если вдруг что-то ещё из мусора попало
*.pyc
__pycache__/
.DS_Store
*.log
*.tmp
*.bak
*.orig
