        f.write("\n10. ФИНАЛЬНЫЕ ВЫВОДЫ\n")
        f.write("-" * 60 + "\n")
        
        if len(df_delta) > 0:
            mean_delta = df_delta['delta_R'].mean()
            std_delta = df_delta['delta_R'].std()
            effect_size = abs(mean_delta) / std_delta if std_delta > 0 else 0
            
            f.write(f"Средний эффект мутаций (ΔR): {mean_delta:.4f}\n")
            f.write(f"Разброс эффектов (σ): {std_delta:.4f}\n")
            f.write(f"Размер эффекта (Коэн d): {effect_size:.4f}\n")
            
            # Классификация эффекта по Коэну
            if effect_size < 0.2:
                f.write("  Эффект: очень маленький\n")
            elif effect_size < 0.5:
                f.write("  Эффект: маленький\n")
            elif effect_size < 0.8:
                f.write("  Эффект: средний\n")
            else:
                f.write("  Эффект: большой\n")
            
            # Рекомендации для дальнейшего анализа
            f.write("\nРекомендации для дальнейшего анализа:\n")
            if effect_size > 0.5:
                f.write("  1. Эффект достаточно велик для дальнейшего изучения\n")
            else:
                f.write("  1. Эффект мал, возможно, требуются дополнительные данные\n")
            
            if len(df_delta) > 1000:
                f.write("  2. Достаточно данных для построения сложных моделей\n")
            elif len(df_delta) > 100:
                f.write("  2. Достаточно данных для линейных моделей\n")
            else:
                f.write("  2. Мало данных, нужна осторожность при интерпретации\n")
        
        f.write("\n" + "=" * 100 + "\n")
        f.write("КОНЕЦ ОТЧЕТА\n")
        f.write("=" * 100 + "\n")

