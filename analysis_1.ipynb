                # Сортируем колонки в правильном порядке
                pivot_table = pivot_table[[f"{ref_nuc}→{alt}" for alt in alts]]
                
                # Создаем heatmap
                fig, ax = plt.subplots(figsize=(10, 8), dpi=DPI)
                
