                    'C': ['A', 'G', 'T'],
                    'A': ['C', 'G', 'T'],
                    'T': ['A', 'C', 'G']
                }
                
                alts = possible_alts[ref_nuc]
                
                # Выбираем топ-20 позиций по среднему |ΔR| для этого исходного нуклеотида
                top_positions_ref = df_ref.groupby('position')['abs_delta_R'].mean().nlargest(20).index
                df_heat = df_ref[df_ref['position'].isin(top_positions_ref)]
                
                if len(df_heat) == 0:
                    continue
                
                # Создаем сводную таблицу
                pivot_table = df_heat.pivot_table(
