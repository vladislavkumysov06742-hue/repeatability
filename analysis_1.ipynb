                             fontsize=9,
                             loc='upper left', 
                             bbox_to_anchor=(1.02, 1),
                             frameon=True,
                             framealpha=1.0,
                             edgecolor='black',
                             facecolor='white')
            
            # График 5D: Частота типов замен
