            )
            
            fig, axes = plt.subplots(2, 2, figsize=(16, 12), dpi=DPI)
            
            # График 5A: Среднее |ΔR| по типам замен
            type_stats = df_delta.groupby('transition_type')['abs_delta_R'].agg(['mean', 'std', 'count']).reset_index()
            
            bars = axes[0, 0].bar(type_stats['transition_type'], type_stats['mean'],
