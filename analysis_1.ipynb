                )
                x_line = np.array([df_delta_top['ref_length'].min(), df_delta_top['ref_length'].max()])
                y_line = intercept + slope * x_line
                axes[0].plot(x_line, y_line, 'r--', linewidth=2, 
                            label=f'R²={r_value**2:.3f}, p={p_value:.3e}')
                axes[0].legend()
            
            cbar1 = plt.colorbar(scatter1, ax=axes[0])
