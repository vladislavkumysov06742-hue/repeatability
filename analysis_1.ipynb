            axes[1, 1].set_xlabel('Количество наблюдений', fontsize=11)
            axes[1, 1].set_title('Топ-10 самых частых мутаций', fontsize=13, fontweight='bold')
            axes[1, 1].grid(True, axis='x', alpha=0.3)
            
            # Добавляем значения на столбцы
            for i, v in enumerate(mutation_counts.values):
                axes[1, 1].text(v + max(mutation_counts.values)*0.01, i, 
                               f'{v}', va='center', fontsize=9, fontweight='bold')
            
            plt.tight_layout()
            fig.savefig(output_dir / 'figure5_mutation_analysis.png', dpi=DPI, bbox_inches='tight')
            plt.show()
            print(f"Рис. 5 сохранен: {output_dir}/figure5_mutation_analysis.png")
        
