            # График 5C: Улучшенный stacked bar plot с процентами и отдельной легендой
            direction_counts = df_delta.groupby(['transition_type', 'change_direction']).size().unstack(fill_value=0)
            
            # Упорядочиваем категории
            order_categories = ['Сильное увеличение', 'Умеренное увеличение', 'Слабое увеличение',
