                'Умеренное уменьшение': '#ff9800',
                'Сильное уменьшение': '#e65100'
            }
            colors_plot = [color_map[cat] for cat in existing_categories]
            
            # Строим stacked bar plot
            bottom = np.zeros(len(direction_pct))
            bars_list = []
            
            for i, category in enumerate(existing_categories):
                bar = axes[1, 0].bar(direction_pct.index, direction_pct[category], 
                                    bottom=bottom, color=colors_plot[i], 
