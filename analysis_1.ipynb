                bars_list.append(bar)
                bottom += direction_pct[category].values
            
            axes[1, 0].set_xlabel('Тип нуклеотидной замены', fontsize=11)
            axes[1, 0].set_ylabel('Доля мутаций (%)', fontsize=11)
            axes[1, 0].set_title('Направление эффекта по типам замен', fontsize=13, fontweight='bold')
