        print("\n" + "="*60)
        print("ФИНАЛЬНАЯ СТАТИСТИКА АНАЛИЗА")
        print("="*60)
        print(f"Всего позиций: {df_all['position'].nunique()}")
        print(f"Всего аллелей: {len(df_all)}")
        print(f"Всего мутаций (ΔR вычислено): {len(df_delta)}")
        
        if len(df_delta) > 0:
            print(f"\nСтатистика ΔR:")
            print(f"  Среднее: {df_delta['delta_R'].mean():.4f}")
            print(f"  Медиана: {df_delta['delta_R'].median():.4f}")
            print(f"  Стандартное отклонение: {df_delta['delta_R'].std():.4f}")
            print(f"  Минимум: {df_delta['delta_R'].min():.4f}")
            print(f"  Максимум: {df_delta['delta_R'].max():.4f}")
            
            increasing = len(df_delta[df_delta['delta_R'] > 0])
            decreasing = len(df_delta[df_delta['delta_R'] < 0])
            neutral = len(df_delta[df_delta['delta_R'] == 0])
            
            print(f"\nНаправление изменений:")
            print(f"  Увеличивают: {increasing} ({increasing/len(df_delta)*100:.1f}%)")
            print(f"  Уменьшают: {decreasing} ({decreasing/len(df_delta)*100:.1f}%)")
            print(f"  Нейтральные: {neutral} ({neutral/len(df_delta)*100:.1f}%)")
            
            transitions = len(df_delta[df_delta['is_transition']])
            print(f"\nТипы мутаций:")
            print(f"  Транзиции: {transitions} ({transitions/len(df_delta)*100:.1f}%)")
            print(f"  Трансверсии: {len(df_delta)-transitions} ({(len(df_delta)-transitions)/len(df_delta)*100:.1f}%)")
        
        print(f"\nВсе графики сохранены в директории: {output_dir}")
        print(f"Полный текстовый отчет сохранен в: {text_output_dir}/full_analysis_report.txt")
        
    else:
        print("Не удалось вычислить ΔR: нет данных для сравнения")
else:
    print("Нет данных для анализа!")
