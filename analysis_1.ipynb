            # Оставляем только те категории, которые есть в данных
            existing_categories = [cat for cat in order_categories if cat in direction_counts.columns]
            direction_counts = direction_counts[existing_categories]
            
            # Переводим в проценты
            direction_pct = direction_counts.div(direction_counts.sum(axis=1), axis=0) * 100
            
            # Цвета для категорий
            color_map = {
                'Сильное увеличение': '#1b5e20',
                'Умеренное увеличение': '#4caf50',
