import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from pathlib import Path
import warnings
warnings.filterwarnings('ignore')

def safe_read_repeatability_file(pos, nuc, results_dir):
    """
    Безопасно читает файл результата. Если файла нет, возвращает DataFrame с одной строкой NaN.
    """
    file_path = Path(results_dir) / f"01KP.{pos}.{nuc}.txt"
    
    try:
        df = pd.read_csv(file_path, sep='\t')
        # Добавляем колонки pos и nuc, если их нет (для удобства)
        df['pos'] = pos
        df['nuc'] = nuc
        return df
    except FileNotFoundError:
        # Создаем "пустую" строку с NaN для метрик
        print(f"  Файл не найден и будет пропущен: {file_path.name}")
        empty_data = {
            'pos': pos, 'nuc': nuc,
            'motif.length': np.nan, 'effective.length': np.nan,
            'repeat.hamming.distance': np.nan,
            'motif.start': np.nan, 'motif.end': np.nan,
            'repeat.start': np.nan, 'repeat.end': np.nan
        }
        return pd.DataFrame([empty_data])
    except Exception as e:
        print(f"  Ошибка чтения файла {file_path.name}: {e}")
        return pd.DataFrame()  # Пустой DataFrame

def calculate_robust_repeatability_metric(results_dir, positions_of_interest, nucleotides=['A','T','G','C']):
    """
    Вычисляет метрику повторяемости (длину самого длинного идеального повтора) для списка позиций,
    устойчиво к отсутствующим файлам.
    """
    results = []
    
    for pos in positions_of_interest:
        for nuc in nucleotides:
            df = safe_read_repeatability_file(pos, nuc, results_dir)
            
            if df.empty:
                # Если DataFrame пустой из-за ошибки, пропускаем
                continue
            
            # --- ПРИМЕНЯЕМ ФИЛЬТРЫ (как в оригинальной функции) ---
            major_arc_start = 5798
            major_arc_end = 16568
            
            filtered = df[
                ~((df['motif.start'] == df['repeat.start']) & (df['motif.end'] == df['repeat.end'])) &
                (df['motif.start'] >= major_arc_start) & (df['motif.end'] <= major_arc_end) &
                (df['repeat.start'] >= major_arc_start) & (df['repeat.end'] <= major_arc_end) &
                (df['repeat.hamming.distance'] == 0) &
                (df['motif.start'] < df['pos']) & (df['pos'] < df['motif.end'])
            ]
            
            # --- НАХОДИМ САМЫЙ ДЛИННЫЙ ПОВТОР ---
            if not filtered.empty:
                # Сортируем по убыванию длины мотива
                longest = filtered.sort_values('motif.length', ascending=False).iloc[0]
                best_length = longest['motif.length']
            else:
                best_length = 0  # Или np.nan, если хотим отличать "нет повторов" от "нет файла"
            
            results.append({
                'position': pos,
                'nucleotide': nuc,
                'longest_perfect_repeat_length': best_length
            })
    
    return pd.DataFrame(results)
