        df_pos['description'] = info['description']
        df_pos['importance'] = info['importance']
        all_positions_data.append(df_pos)
    else:
        print(f"  Предупреждение: Нет данных для позиции {pos}")

# Объединяем все данные
if all_positions_data:
    df_all = pd.concat(all_positions_data, ignore_index=True)
    print(f"\nУспешно загружено данных: {len(df_all)} записей")
    
    # Показываем сводку
    print("\nСводка по позициям:")
    for pos in positions_info.keys():
        subset = df_all[df_all['position'] == pos]
        if len(subset) > 0:
            ref_row = subset[subset['is_reference']].iloc[0] if any(subset['is_reference']) else subset.iloc[0]
            print(f"  Позиция {pos} ({positions_info[pos]['gene']}): {len(subset)} аллелей, "
                  f"реф. длина={ref_row['mean_length']:.1f}, GC={ref_row['mean_gc']:.1f}%")
else:
    print("Нет данных для анализа!")
    df_all = pd.DataFrame()

# Сначала вычисляем ΔR для каждой позиции
def calculate_delta_R_for_positions(df):
    """Вычисляет ΔR относительно референсного аллеля для каждой позиции"""
    delta_data = []
    
    for pos in df['position'].unique():
        pos_data = df[df['position'] == pos]
        ref_data = pos_data[pos_data['is_reference']]
        
        if len(ref_data) == 0:
            continue
            
        ref_row = ref_data.iloc[0]
        
        for _, row in pos_data.iterrows():
            if not row['is_reference']:
                # ΔR = (метрика аллеля) - (метрика референса)
                delta_R_length = row['mean_length'] - ref_row['mean_length']
                delta_R_effective = row['mean_effective'] - ref_row['mean_effective']
                delta_GC = row['mean_gc'] - ref_row['mean_gc']
                
                delta_data.append({
                    'position': pos,
                    'gene': row['gene'],
                    'ref': ref_row['nucleotide'],
                    'alt': row['nucleotide'],
                    'ref_length': ref_row['mean_length'],
                    'alt_length': row['mean_length'],
                    'delta_R': delta_R_length,
                    'abs_delta_R': abs(delta_R_length),
                    'delta_R_effective': delta_R_effective,
                    'delta_GC': delta_GC,
                    'mutation': f"{ref_row['nucleotide']}→{row['nucleotide']}",
                    'is_transition': is_transition(ref_row['nucleotide'], row['nucleotide'])
                })
    
    return pd.DataFrame(delta_data)

def is_transition(ref, alt):
    """Определяет, является ли замена транзицией"""
    transitions = {('A', 'G'), ('G', 'A'), ('C', 'T'), ('T', 'C')}
    return (ref, alt) in transitions

# Вычисляем ΔR
if not df_all.empty:
    df_delta = calculate_delta_R_for_positions(df_all)
    
    # Рис. 1: Scatter plot с регрессией
    fig, axes = plt.subplots(1, 2, figsize=(14, 6), dpi=DPI)
    
    # График 1A: Длина референса vs |ΔR|
    scatter1 = axes[0].scatter(df_delta['ref_length'], df_delta['abs_delta_R'],
                              c=df_delta['delta_GC'], cmap='coolwarm',
                              alpha=0.7, s=80, edgecolor='black', linewidth=0.5)
    
    axes[0].set_xlabel('Средняя длина референсного повтора (нуклеотиды)', fontsize=11)
    axes[0].set_ylabel('|ΔR| (абсолютное изменение длины)', fontsize=11)
    axes[0].set_title('Зависимость |ΔR| от длины референсного повтора', fontsize=13, fontweight='bold')
    axes[0].grid(True, alpha=0.3)
    
    # Линейная регрессия (если есть вариация)
    if df_delta['ref_length'].nunique() > 1 and df_delta['abs_delta_R'].nunique() > 1:
        slope, intercept, r_value, p_value, std_err = stats.linregress(
            df_delta['ref_length'], df_delta['abs_delta_R']
        )
        x_line = np.array([df_delta['ref_length'].min(), df_delta['ref_length'].max()])
        y_line = intercept + slope * x_line
        axes[0].plot(x_line, y_line, 'r--', linewidth=2, 
                    label=f'R²={r_value**2:.3f}, p={p_value:.3e}')
        axes[0].legend()
    
    # Цветовая шкала
    cbar1 = plt.colorbar(scatter1, ax=axes[0])
    cbar1.set_label('ΔGC (%)', fontsize=10)
    
    # График 1B: Распределение ΔR
    axes[1].hist(df_delta['delta_R'], bins=20, edgecolor='black', alpha=0.7, color='steelblue')
    axes[1].set_xlabel('ΔR (изменение длины повтора)', fontsize=11)
    axes[1].set_ylabel('Частота', fontsize=11)
    axes[1].set_title('Распределение ΔR для ключевых позиций', fontsize=13, fontweight='bold')
    axes[1].axvline(x=0, color='red', linestyle='--', linewidth=2, alpha=0.7)
    axes[1].grid(True, alpha=0.3)
    
    # Добавляем статистику
    mean_delta = df_delta['delta_R'].mean()
    std_delta = df_delta['delta_R'].std()
    axes[1].text(0.95, 0.95, f'μ = {mean_delta:.3f}\nσ = {std_delta:.3f}\nn = {len(df_delta)}', 
                transform=axes[1].transAxes, fontsize=10,
                verticalalignment='top', horizontalalignment='right',
                bbox=dict(boxstyle='round', facecolor='white', alpha=0.8))
    
    plt.suptitle('РИС. 1: Влияние мутаций на длину повтора в ключевых позициях mtDNA', 
                fontsize=15, fontweight='bold', y=1.02)
    plt.tight_layout()
    
    # Сохраняем график
    fig.savefig(output_dir / 'figure1_scatter_regression.png', dpi=DPI, bbox_inches='tight')
    plt.show()
    
    print(f"Рис. 1 сохранен: {output_dir}/figure1_scatter_regression.png")
    print(f"Статистика ΔR: среднее = {mean_delta:.3f}, SD = {std_delta:.3f}")

# Рис. 2: Grouped box plot
if not df_delta.empty:
    # Создаем категории ΔGC
    df_delta['delta_GC_group'] = pd.cut(df_delta['delta_GC'],
                                        bins=[-float('inf'), -5, 0, 5, float('inf')],
                                        labels=['ΔGC < -5%', '-5% ≤ ΔGC < 0%', 
                                                '0% ≤ ΔGC < 5%', 'ΔGC ≥ 5%'])
    
    fig, axes = plt.subplots(1, 2, figsize=(14, 6), dpi=DPI)
    
    # График 2A: Box plot
    bp1 = axes[0].boxplot([df_delta[df_delta['delta_GC_group'] == group]['delta_R'] 
                          for group in df_delta['delta_GC_group'].cat.categories],
                         labels=df_delta['delta_GC_group'].cat.categories,
                         patch_artist=True)
    
    # Настройка цветов
    colors = ['lightcoral', 'lightsalmon', 'lightgreen', 'mediumseagreen']
    for patch, color in zip(bp1['boxes'], colors):
        patch.set_facecolor(color)
        patch.set_alpha(0.7)
    
    axes[0].set_xlabel('Группа изменения GC-состава', fontsize=11)
    axes[0].set_ylabel('ΔR (изменение длины повтора)', fontsize=11)
    axes[0].set_title('Влияние изменения GC-состава на ΔR', fontsize=13, fontweight='bold')
    axes[0].axhline(y=0, color='red', linestyle='--', linewidth=2, alpha=0.5)
    axes[0].tick_params(axis='x', rotation=45)
    axes[0].grid(True, axis='y', alpha=0.3)
    
    # График 2B: Violin plot с разбивкой по позициям
    # Создаем комбинированные группы: позиция + ΔGC группа
    df_delta['pos_gc_group'] = df_delta['position'].astype(str) + ' ' + df_delta['delta_GC_group'].astype(str)
    
    # Ограничим количество групп для читаемости
    unique_groups = df_delta['pos_gc_group'].unique()[:8]  # Первые 8 групп
    
    if len(unique_groups) > 1:
        violin_data = [df_delta[df_delta['pos_gc_group'] == group]['delta_R'] 
                      for group in unique_groups]
        
        parts = axes[1].violinplot(violin_data, showmeans=True, showmedians=True)
        
        # Цвета для violin plot
        for pc in parts['bodies']:
            pc.set_facecolor('skyblue')
            pc.set_alpha(0.7)
            pc.set_edgecolor('black')
        
        axes[1].set_xlabel('Позиция + группа ΔGC', fontsize=11)
        axes[1].set_ylabel('ΔR (изменение длины повтора)', fontsize=11)
        axes[1].set_title('ΔR по позициям и группам ΔGC', fontsize=13, fontweight='bold')
        axes[1].set_xticks(range(1, len(unique_groups) + 1))
        axes[1].set_xticklabels(unique_groups, rotation=45, ha='right')
        axes[1].axhline(y=0, color='red', linestyle='--', linewidth=2, alpha=0.5)
        axes[1].grid(True, axis='y', alpha=0.3)
    else:
        axes[1].text(0.5, 0.5, 'Недостаточно групп для violin plot', 
                    ha='center', va='center', transform=axes[1].transAxes)
        axes[1].set_axis_off()
    
    plt.suptitle('РИС. 2: Взаимосвязь изменения GC-состава и ΔR', 
                fontsize=15, fontweight='bold', y=1.02)
    plt.tight_layout()
    
    # Сохраняем график
    fig.savefig(output_dir / 'figure2_boxplot_deltaGC.png', dpi=DPI, bbox_inches='tight')
    plt.show()
    
    print(f"Рис. 2 сохранен: {output_dir}/figure2_boxplot_deltaGC.png")

# Рис. 3: Heatmap
if not df_delta.empty and len(df_delta) > 10:
    # Подготовка данных для heatmap
    heat_data = df_delta.dropna(subset=['ref_length', 'delta_GC', 'delta_R'])
    
    # Создаем бины
    length_bins = 6
    gc_bins = 6
    
    heat_data['length_bin'] = pd.cut(heat_data['ref_length'], bins=length_bins, labels=False)
    heat_data['gc_bin'] = pd.cut(heat_data['delta_GC'], bins=gc_bins, labels=False)
    
    # Сводная таблица: среднее |ΔR| по бинам
    pivot_table = heat_data.pivot_table(
        values='abs_delta_R',
        index='length_bin',
        columns='gc_bin',
        aggfunc='mean',
        fill_value=0
    )
    
    fig, ax = plt.subplots(figsize=(10, 8), dpi=DPI)
    
    # Heatmap
    im = ax.imshow(pivot_table.values, cmap='YlOrRd', aspect='auto', 
                   interpolation='nearest')
    
    # Подписи осей
    ax.set_xlabel('Бин изменения GC-состава (ΔGC)', fontsize=12)
    ax.set_ylabel('Бин длины референсного повтора', fontsize=12)
    ax.set_title('РИС. 3: Среднее |ΔR| по длине повтора и ΔGC', fontsize=14, fontweight='bold')
    
    # Цветовая шкала
    cbar = plt.colorbar(im, ax=ax, shrink=0.8)
    cbar.set_label('Среднее |ΔR|', fontsize=11)
    
    # Добавляем значения в ячейки
    for i in range(pivot_table.shape[0]):
        for j in range(pivot_table.shape[1]):
            val = pivot_table.iloc[i, j]
            if val > 0:
                text_color = "black" if val < pivot_table.values.max()/2 else "white"
                ax.text(j, i, f'{val:.2f}', ha="center", va="center", 
                       color=text_color, fontsize=9, fontweight='bold')
    
    # Настройка тиков
    ax.set_xticks(range(pivot_table.shape[1]))
    ax.set_yticks(range(pivot_table.shape[0]))
    
    # Подписи для бинов (примерные диапазоны)
    if 'ref_length' in heat_data.columns:
        length_ranges = pd.cut(heat_data['ref_length'], bins=length_bins, retbins=True)[1]
        y_labels = [f'{length_ranges[i]:.1f}-{length_ranges[i+1]:.1f}' 
                   for i in range(len(length_ranges)-1)]
        if len(y_labels) == pivot_table.shape[0]:
            ax.set_yticklabels(y_labels)
    
    if 'delta_GC' in heat_data.columns:
        gc_ranges = pd.cut(heat_data['delta_GC'], bins=gc_bins, retbins=True)[1]
        x_labels = [f'{gc_ranges[i]:.1f}-{gc_ranges[i+1]:.1f}' 
                   for i in range(len(gc_ranges)-1)]
        if len(x_labels) == pivot_table.shape[1]:
            ax.set_xticklabels(x_labels, rotation=45)
    
    plt.tight_layout()
    
    # Сохраняем график
    fig.savefig(output_dir / 'figure3_heatmap_length_gc.png', dpi=DPI, bbox_inches='tight')
    plt.show()
    
    print(f"Рис. 3 сохранен: {output_dir}/figure3_heatmap_length_gc.png")

# Рис. 4: Схема common repeat для позиции 8473 (самой важной)
def visualize_8473_repeat():
    """Визуализация common repeat для позиции 8473"""
    
    # Загружаем данные для позиции 8473
    pos = 8473
    ref_nuc = 'T'
    alt_nuc = 'C'  # Мутация гаплогруппы D4a
    
    ref_file = Path("./data/2_derived/01KP/") / f"01KP.{pos}.{ref_nuc}.txt"
    alt_file = Path("./data/2_derived/01KP/") / f"01KP.{pos}.{alt_nuc}.txt"
    
    if not ref_file.exists() or not alt_file.exists():
        print(f"Файлы для позиции {pos} не найдены")
        return
    
    try:
        ref_df = pd.read_csv(ref_file, sep='\t')
        alt_df = pd.read_csv(alt_file, sep='\t')
        
        # Ищем common repeat (13-парный прямой повтор)
        # Ищем мотивы длиной около 13 нуклеотидов
        ref_13 = ref_df[np.abs(ref_df['motif.length'] - 13) <= 2]
        alt_13 = alt_df[np.abs(alt_df['motif.length'] - 13) <= 2]
        
        if len(ref_13) == 0 or len(alt_13) == 0:
            # Берем самые длинные мотивы
            ref_13 = ref_df.sort_values('motif.length', ascending=False).head(1)
            alt_13 = alt_df.sort_values('motif.length', ascending=False).head(1)
        
        ref_motif = ref_13.iloc[0]
        alt_motif = alt_13.iloc[0]
        
        # Создаем визуализацию
        fig, axes = plt.subplots(2, 1, figsize=(14, 8), dpi=DPI)
        
        # Панель A: Референсный repeat (T аллель)
        ax1 = axes[0]
        motif_seq = ref_motif['motif.seq']
        motif_len = len(motif_seq)
        
        # Позиция мутации в мотиве
        pos_in_motif = pos - ref_motif['motif.start']
        
        # Рисуем мотив
        for i, nucleotide in enumerate(motif_seq):
            # Цвета для нуклеотидов
            if nucleotide == 'A':
                color = 'red'
            elif nucleotide == 'T':
                color = 'blue'
            elif nucleotide == 'G':
                color = 'orange'
            elif nucleotide == 'C':
                color = 'green'
            else:
                color = 'gray'
            
            # Особый цвет для позиции 8473
            if i == pos_in_motif:
                # Красная рамка для позиции мутации
                rect = plt.Rectangle((i, 0), 1, 1, facecolor=color, 
                                   edgecolor='red', linewidth=3, alpha=0.8)
                ax1.add_patch(rect)
                ax1.text(i + 0.5, 0.5, nucleotide, ha='center', va='center', 
                        fontsize=14, fontweight='bold', color='white')
            else:
                rect = plt.Rectangle((i, 0), 1, 1, facecolor=color, alpha=0.7)
                ax1.add_patch(rect)
                ax1.text(i + 0.5, 0.5, nucleotide, ha='center', va='center', 
                        fontsize=12, color='white')
        
        ax1.set_xlim(-0.5, motif_len + 0.5)
        ax1.set_ylim(-0.2, 1.2)
        ax1.set_title(f'Common Repeat до мутации: позиция {pos} = {ref_nuc}\n'
                     f'Ген: {positions_info[pos]["gene"]}, Длина: {motif_len} нт', 
                     fontsize=13, fontweight='bold')
        ax1.set_ylabel('Референсный аллель', fontsize=11)
        ax1.set_xticks(range(motif_len))
        ax1.set_xticklabels([str(ref_motif['motif.start'] + i) for i in range(motif_len)], 
                           rotation=45, fontsize=9)
        ax1.set_yticks([])
        
        # Подчеркиваем позицию 8473
        ax1.annotate('Позиция 8473', xy=(pos_in_motif + 0.5, -0.1), 
                    xytext=(pos_in_motif + 0.5, -0.15),
                    ha='center', va='top', fontsize=10, fontweight='bold',
                    arrowprops=dict(arrowstyle='->', color='red', lw=2))
        
        # Панель B: После мутации (C аллель)
        ax2 = axes[1]
        alt_seq = alt_motif['motif.seq']
        alt_len = len(alt_seq)
        
        # Позиция мутации в мотиве
        alt_pos_in_motif = pos - alt_motif['motif.start']
        
        for i, nucleotide in enumerate(alt_seq):
            # Цвета для нуклеотидов
            if nucleotide == 'A':
                color = 'red'
            elif nucleotide == 'T':
                color = 'blue'
            elif nucleotide == 'G':
                color = 'orange'
            elif nucleotide == 'C':
                color = 'green'
            else:
                color = 'gray'
            
            # Особый цвет для позиции 8473
            if i == alt_pos_in_motif:
                # Зеленая рамка для мутировавшей позиции
                rect = plt.Rectangle((i, 0), 1, 1, facecolor=color, 
                                   edgecolor='green', linewidth=3, alpha=0.8)
                ax2.add_patch(rect)
                ax2.text(i + 0.5, 0.5, nucleotide, ha='center', va='center', 
                        fontsize=14, fontweight='bold', color='white')
            else:
                rect = plt.Rectangle((i, 0), 1, 1, facecolor=color, alpha=0.7)
                ax2.add_patch(rect)
                ax2.text(i + 0.5, 0.5, nucleotide, ha='center', va='center', 
                        fontsize=12, color='white')
        
        ax2.set_xlim(-0.5, max(motif_len, alt_len) + 0.5)
        ax2.set_ylim(-0.2, 1.2)
        ax2.set_title(f'Common Repeat после мутации: {ref_nuc}→{alt_nuc}\n'
                     f'Гаплогруппа D4a: снижение делеций, увеличение продолжительности жизни', 
                     fontsize=13, fontweight='bold')
        ax2.set_ylabel('Альтернативный аллель', fontsize=11)
        ax2.set_xlabel('Позиция в геноме', fontsize=11)
        ax2.set_xticks(range(alt_len))
        ax2.set_xticklabels([str(alt_motif['motif.start'] + i) for i in range(alt_len)], 
                           rotation=45, fontsize=9)
        ax2.set_yticks([])
        
        # Стрелка изменения
        ax2.annotate('Мутация', xy=(alt_pos_in_motif + 0.5, -0.1), 
                    xytext=(alt_pos_in_motif + 0.5, -0.15),
                    ha='center', va='top', fontsize=10, fontweight='bold',
                    arrowprops=dict(arrowstyle='->', color='green', lw=2))
        
        # Сравнение метрик
        delta_length = alt_motif['motif.length'] - ref_motif['motif.length']
        delta_effective = alt_motif.get('effective.length', alt_motif['motif.length']) - \
                         ref_motif.get('effective.length', ref_motif['motif.length'])
        
        # Информационная панель
        info_text = (f'Сравнение метрик:\n'
                    f'• Длина мотива: {ref_motif["motif.length"]} → {alt_motif["motif.length"]} '
                    f'(Δ = {delta_length:+d})\n'
                    f'• Эффективная длина: {ref_motif.get("effective.length", "N/A")} → '
                    f'{alt_motif.get("effective.length", "N/A")} (Δ = {delta_effective:+d})\n'
                    f'• Координаты: {ref_motif["motif.start"]}-{ref_motif["motif.end"]}\n'
                    f'• Perfect repeats: {ref_motif.get("repeat.hamming.distance", "N/A")} ошибок')
        
        plt.figtext(0.02, 0.02, info_text, fontsize=10, 
                   bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.5))
        
        plt.suptitle('РИС. 4: Common Repeat в позиции 8473 (MT-ATP8/MT-ATP6)\n'
                    'Центральный нуклеотид 13-парного прямого повтора', 
                    fontsize=16, fontweight='bold', y=1.02)
        
        plt.tight_layout(rect=[0, 0.1, 1, 0.95])
        
        # Сохраняем график
        fig.savefig(output_dir / 'figure4_common_repeat_8473.png', dpi=DPI, bbox_inches='tight')
        plt.show()
        
        print(f"Рис. 4 сохранен: {output_dir}/figure4_common_repeat_8473.png")
        
    except Exception as e:
        print(f"Ошибка визуализации: {e}")
        import traceback
