# Рис. 5: Барплот сравнения типов замен
if not df_delta.empty:
    # Добавляем информацию о типе замены
    df_delta['transition_type'] = df_delta.apply(
        lambda row: 'Транзиция' if row['is_transition'] else 'Трансверсия', axis=1
    )

    # Добавляем информацию о направлении изменения
    df_delta['change_direction'] = df_delta['delta_R'].apply(
