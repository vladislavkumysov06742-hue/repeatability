    )

    fig, axes = plt.subplots(1, 3, figsize=(15, 5), dpi=DPI)

    # График 5A: Среднее |ΔR| по типам замен
    type_stats = df_delta.groupby('transition_type')['abs_delta_R'].agg(['mean', 'std', 'count']).reset_index()

    bars1 = axes[0].bar(type_stats['transition_type'], type_stats['mean'],
                       yerr=type_stats['std'], capsize=8,
                       color=['skyblue', 'lightcoral'], alpha=0.8, edgecolor='black')

    axes[0].set_xlabel('Тип нуклеотидной замены', fontsize=11)
    axes[0].set_ylabel('Среднее |ΔR|', fontsize=11)
    axes[0].set_title('Влияние типа замены на величину эффекта', fontsize=13, fontweight='bold')
    axes[0].grid(True, axis='y', alpha=0.3)

    # Добавляем значения
    for i, (_, row) in enumerate(type_stats.iterrows()):
        axes[0].text(i, row['mean'] + row['std'] + 0.01,
                    f'{row["mean"]:.3f}\n(n={int(row["count"])})',
                    ha='center', va='bottom', fontsize=9)

    # График 5B: Распределение ΔR по типам замен
    # Box plot
    bp = axes[1].boxplot([df_delta[df_delta['transition_type'] == t]['delta_R']
                         for t in df_delta['transition_type'].unique()],
