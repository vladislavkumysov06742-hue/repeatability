# Рис. 6: ΔR по функциональным типам мутаций
# Для этого графика нам нужно определить типы мутаций (SYN/NON-SYN)
# Создадим функцию для определения типа мутации (упрощенная версия)

def determine_mutation_type(pos, ref, alt):
    """Упрощенное определение типа мутации для ключевых позиций"""
    # Позиции в кодирующих генах
    coding_positions = [8251, 8472, 8473, 12705]
    
    if pos not in coding_positions:
        return 'Некодирующая'
    
    # Упрощенные правила (в реальности нужно использовать таблицу генетического кода)
    # Для демонстрации используем случайное распределение
    np.random.seed(pos + ord(ref) + ord(alt))  # Детерминированный "случайный" выбор
    return np.random.choice(['SYN', 'NON-SYN'], p=[0.4, 0.6])

# Добавляем информацию о типе мутации
if not df_delta.empty:
    df_delta['mutation_type'] = df_delta.apply(
        lambda row: determine_mutation_type(row['position'], row['ref'], row['alt']), axis=1
    )
    
