                        patch_artist=True, widths=0.6)

    # Цвета
    colors = ['skyblue', 'lightcoral']
    for patch, color in zip(bp['boxes'], colors):
        patch.set_facecolor(color)
        patch.set_alpha(0.7)

    axes[1].set_xlabel('Тип нуклеотидной замены', fontsize=11)
    axes[1].set_ylabel('ΔR (изменение длины)', fontsize=11)
    axes[1].set_title('Распределение ΔR по типам замен', fontsize=13, fontweight='bold')
    axes[1].axhline(y=0, color='red', linestyle='--', alpha=0.5)
    axes[1].grid(True, axis='y', alpha=0.3)

    # График 5C: Направление эффекта по типам замен
    direction_counts = df_delta.groupby(['transition_type', 'change_direction']).size().unstack(fill_value=0)
    direction_pct = direction_counts.div(direction_counts.sum(axis=1), axis=0) * 100

    direction_pct.plot(kind='bar', stacked=True, ax=axes[2],
                      color=['green', 'red', 'gray'], alpha=0.8, edgecolor='black')

    axes[2].set_xlabel('Тип нуклеотидной замены', fontsize=11)
    axes[2].set_ylabel('Доля мутаций (%)', fontsize=11)
    axes[2].set_title('Направление эффекта по типам замен', fontsize=13, fontweight='bold')
    axes[2].legend(title='Эффект на повторяемость', fontsize=9)
    axes[2].grid(True, axis='y', alpha=0.3)

    # Статистика различий
    if df_delta['transition_type'].nunique() == 2:
        trans = df_delta[df_delta['transition_type'] == 'Транзиция']['delta_R']
        transv = df_delta[df_delta['transition_type'] == 'Трансверсия']['delta_R']

        if len(trans) > 1 and len(transv) > 1:
            t_stat, p_val = stats.ttest_ind(trans, transv, equal_var=False)
            axes[1].text(0.95, 0.95, f't-test: p = {p_val:.3e}',
                        transform=axes[1].transAxes, ha='right', va='top',
                        bbox=dict(boxstyle='round', facecolor='white', alpha=0.8))

    plt.suptitle('РИС. 5: Сравнение влияния транзиций и трансверсий на повторяемость',
                fontsize=15, fontweight='bold', y=1.02)
    plt.tight_layout()

