import numpy as np
import pandas as pd
from Bio import SeqIO
import time
import sys
from pathlib import Path
from concurrent.futures import ProcessPoolExecutor, ThreadPoolExecutor
import multiprocessing as mp

sys.path.append('..')
from functions.RetrieveAllRepeatsCoveringGivenPositionAndNucleotideInSequence_optimized import (
    retrieve_all_repeats_covering_given_position_and_nucleotide_in_sequence
)

mtDNA_record = next(SeqIO.parse("../data/1_raw/Homo_sapients.mtDNA.fasta", "fasta"))
mtDNA_seq = str(mtDNA_record.seq)
print(f"Длина mtDNA: {len(mtDNA_seq)}")

output_folder = "/home/popadin/Repeatability/data/2_derived/01KP"

def process_position_nucleotide(args):
    """Функция для параллельной обработки позиции и нуклеотида"""
    seq, pos, nuc, output_folder = args
    return retrieve_all_repeats_covering_given_position_and_nucleotide_in_sequence(
        seq, pos, nuc, output_folder
    )

test_positions = [8251, 8472, 8473, 12705, 14798, 16223]
nucleotides = ['A', 'T', 'G', 'C']

tasks = [(mtDNA_seq, pos, nuc, output_folder) 
         for pos in test_positions for nuc in nucleotides]

print(f"Всего задач: {len(tasks)}")

start_time = time.time()

with ProcessPoolExecutor(max_workers=mp.cpu_count()) as executor:
    results = list(executor.map(process_position_nucleotide, tasks))

total_time = time.time() - start_time
print(f"Обработка завершена за {total_time:.2f} сек")
print(f"Среднее время на задачу: {total_time/len(tasks):.2f} сек")

def batch_process_positions(seq, start_pos, end_pos, nucleotides, output_folder):
    """Пакетная обработка диапазона позиций"""
    results = []
    for pos in range(start_pos, end_pos + 1):
        for nuc in nucleotides:
            result = retrieve_all_repeats_covering_given_position_and_nucleotide_in_sequence(
                seq, pos, nuc, output_folder
            )
            results.append((pos, nuc, len(result)))
    return results

seq_length = len(mtDNA_seq)
nucleotides = ['A', 'T', 'G', 'C']
output_folder = "/home/popadin/Repeatability/data/2_derived/01KP"

start_pos = 1633
batch_size = 100  # Обрабатываем по 100 позиций за раз

total_positions = seq_length - start_pos + 1
num_batches = (total_positions + batch_size - 1) // batch_size

print(f"Всего позиций для обработки: {total_positions}")
print(f"Размер батча: {batch_size}")
print(f"Количество батчей: {num_batches}")

start_time = time.time()
total_processed = 0

for batch_num in range(num_batches):
    batch_start = start_pos + batch_num * batch_size
    batch_end = min(batch_start + batch_size - 1, seq_length)
    
    print(f"\nБатч {batch_num + 1}/{num_batches}: позиции {batch_start}-{batch_end}")
    
    tasks = []
    for pos in range(batch_start, batch_end + 1):
        for nuc in nucleotides:
            tasks.append((mtDNA_seq, pos, nuc, output_folder))
    
    with ProcessPoolExecutor(max_workers=min(mp.cpu_count(), 8)) as executor:
        batch_results = list(executor.map(process_position_nucleotide, tasks))
    
    total_processed += len(tasks)
    elapsed = time.time() - start_time
    avg_time_per_task = elapsed / total_processed if total_processed > 0 else 0
    
    print(f"  Обработано: {total_processed} задач")
    print(f"  Прошло времени: {elapsed:.1f} сек")
    print(f"  Среднее время на задачу: {avg_time_per_task:.3f} сек")
    
    remaining_tasks = total_positions * len(nucleotides) - total_processed
    if avg_time_per_task > 0 and remaining_tasks > 0:
        est_remaining = avg_time_per_task * remaining_tasks
        print(f"  Оценочное время до завершения: {est_remaining:.1f} сек")

print(f"\n{'='*50}")
print(f"ВСЕ ОБРАБОТКИ ЗАВЕРШЕНЫ")
print(f"Общее время: {time.time() - start_time:.1f} сек")
print(f"Обработано задач: {total_processed}")
print(f"Среднее время на задачу: {(time.time() - start_time)/total_processed:.3f} сек")
