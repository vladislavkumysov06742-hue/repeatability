import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from pathlib import Path
from scipy.stats import pearsonr
from tqdm import tqdm
import re

# ==================== НАСТРОЙКИ ====================
HUMAN_RESULTS_DIR = Path("./all/cleaned")   			# замените на реальный путь
PIKA_RESULTS_DIR  = Path("./data/2_derived/01KP/cleaned")    	# замените на реальный путь
WINDOW_SIZE = 100          			     		# размер скользящего окна (в нуклеотидах)
NUCLEOTIDES = ['A', 'T', 'G', 'C']
# ===================================================

def get_genome_length_from_files(results_dir):
    """
    Определяет длину генома как максимальный номер позиции
    среди всех файлов 01KP.*.txt в папке results_dir.
    """
    max_pos = 0
    pattern = re.compile(r'01KP\.(\d+)\.([ATCG])\.txt$')
    for fpath in results_dir.glob("01KP.*.txt"):
        match = pattern.match(fpath.name)
        if match:
            pos = int(match.group(1))
            if pos > max_pos:
                max_pos = pos
    if max_pos == 0:
        raise ValueError(f"Не найдено файлов 01KP.*.txt в {results_dir}")
    return max_pos

def load_repeatability_for_genome(results_dir, genome_len=None):
    """
    Загружает все файлы 01KP.*.txt из results_dir и возвращает массив
    максимальной повторяемости (max effective.length для perfect repeats)
    для каждой позиции.
    
    Если genome_len не задан, определяется автоматически из файлов.
    """
    if genome_len is None:
        genome_len = get_genome_length_from_files(results_dir)
    
    repeatability = np.zeros((genome_len, 4), dtype=float)
    nuc_to_idx = {nuc: i for i, nuc in enumerate(NUCLEOTIDES)}
    
    # Предварительно создадим список всех ожидаемых файлов для быстрой проверки
    # Но проще проходим по всем существующим файлам и заполняем массив.
    # Для отсутствующих комбинаций значение останется 0 (уже инициализировано).
    
    files = list(results_dir.glob("01KP.*.txt"))
    # Используем tqdm для прогресс-бара, но так как файлов может быть много, покажем общее количество
    for fpath in tqdm(files, desc=f"Loading {results_dir.name}"):
        # Извлекаем позицию и нуклеотид из имени файла
        # Формат: 01KP.{pos}.{nuc}.txt
        parts = fpath.stem.split('.')  # "01KP", "8473", "T"
        if len(parts) != 3 or parts[0] != "01KP":
            continue
        try:
            pos = int(parts[1])
            nuc = parts[2]
            if nuc not in nuc_to_idx:
                continue
        except:
            continue
        
        if pos < 1 or pos > genome_len:
            continue  # на всякий случай
        
        try:
            df = pd.read_csv(fpath, sep='\t')
        except:
            continue
        
        perfect = df[df['repeat.hamming.distance'] == 0]
        if len(perfect) > 0:
            best = perfect['effective.length'].max()
            repeatability[pos-1, nuc_to_idx[nuc]] = best
        # иначе остаётся 0
    
    # Для каждой позиции берём максимум по нуклеотидам
    profile = repeatability.max(axis=1)
    return profile

def rolling_correlation(x, y, window):
    """Вычисляет скользящую корреляцию Пирсона между двумя массивами."""
    if len(x) != len(y):
        raise ValueError("Массивы должны быть одинаковой длины")
    n = len(x)
    corrs = np.full(n, np.nan)
    half = window // 2
    for i in range(half, n - half):
        start = i - half
        end = i + half + 1
        x_win = x[start:end]
        y_win = y[start:end]
        mask = ~(np.isnan(x_win) | np.isnan(y_win))
        if np.sum(mask) >= 3:
            corr, _ = pearsonr(x_win[mask], y_win[mask])
            corrs[i] = corr
    return corrs

# ==================== ОСНОВНОЙ АНАЛИЗ ====================
print("Определение длины геномов по файлам...")
human_len = get_genome_length_from_files(HUMAN_RESULTS_DIR)
pika_len = get_genome_length_from_files(PIKA_RESULTS_DIR)
print(f"Длина генома человека: {human_len} п.н.")
print(f"Длина генома пищухи: {pika_len} п.н.")

# Можно использовать общую длину как максимум из двух (если они различаются)
# Для корреляции лучше обрезать до минимальной длины, чтобы позиции соответствовали.
# Предполагаем, что геномы гомологичны и выровнены, поэтому возьмём min(len1, len2)
common_len = min(human_len, pika_len)
print(f"Используем общую длину для сравнения: {common_len} п.н.")

print("Загрузка данных для человека...")
human_profile = load_repeatability_for_genome(HUMAN_RESULTS_DIR, genome_len=common_len)
print("Загрузка данных для пищухи...")
pika_profile = load_repeatability_for_genome(PIKA_RESULTS_DIR, genome_len=common_len)

# Общая корреляция (только позиции, где оба значения > 0, но можно и все)
mask = (human_profile > 0) & (pika_profile > 0)
if np.sum(mask) > 1:
    overall_corr, p_value = pearsonr(human_profile[mask], pika_profile[mask])
    print(f"\nОбщая корреляция Пирсона (только позиции с повторами в обоих геномах): r = {overall_corr:.4f}, p = {p_value:.2e}")
else:
    overall_corr = np.nan
    print("Недостаточно данных для общей корреляции.")

# Скользящая корреляция
rolling_corr = rolling_correlation(human_profile, pika_profile, WINDOW_SIZE)

# ==================== ВИЗУАЛИЗАЦИЯ ====================
fig, axes = plt.subplots(3, 1, figsize=(14, 12), sharex=True)

# 1. Профили повторяемости
axes[0].plot(human_profile, label='Human', alpha=0.7, color='blue')
axes[0].plot(pika_profile, label='Pika', alpha=0.7, color='orange')
axes[0].set_ylabel('Max repeatability\n(effective length)')
axes[0].legend()
axes[0].set_title('Профили повторяемости (максимум по нуклеотидам)')
axes[0].grid(alpha=0.3)

# 2. Скользящая корреляция
axes[1].plot(rolling_corr, color='green')
axes[1].axhline(y=0, color='gray', linestyle='--', alpha=0.5)
axes[1].set_ylabel(f'Rolling correlation (window={WINDOW_SIZE})')
axes[1].set_ylim(-1, 1)
axes[1].grid(alpha=0.3)
axes[1].set_title(f'Скользящая корреляция Пирсона (окно {WINDOW_SIZE} п.н.)')

# 3. Scatter plot
axes[2].scatter(human_profile, pika_profile, alpha=0.3, s=1)
if not np.isnan(overall_corr):
    z = np.polyfit(human_profile, pika_profile, 1)
    p = np.poly1d(z)
    x_line = np.linspace(0, max(human_profile.max(), pika_profile.max()), 100)
    axes[2].plot(x_line, p(x_line), "r--", label=f'r = {overall_corr:.3f}')
axes[2].set_xlabel('Human repeatability')
axes[2].set_ylabel('Pika repeatability')
axes[2].legend()
axes[2].grid(alpha=0.3)
axes[2].set_title('Сравнение повторяемости позиция-позиция')
axes[2].set_xlim(0, None)
axes[2].set_ylim(0, None)

plt.tight_layout()
plt.savefig('repeatability_comparison.png', dpi=150)
plt.show()

# Сохраним результаты
summary_df = pd.DataFrame({
    'position': np.arange(1, common_len+1),
    'human_repeatability': human_profile,
    'pika_repeatability': pika_profile,
    'rolling_correlation': rolling_corr
})
summary_df.to_csv('repeatability_comparison.csv', index=False)

print("\nРезультаты сохранены в 'repeatability_comparison.csv' и 'repeatability_comparison.png'")
