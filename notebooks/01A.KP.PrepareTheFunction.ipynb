print(f"Мотив (позиции {start+1}-{end}): {motif}")
print(f"Длина мотива: {len(motif)}")

max_mismatch = 1  # 20% для длины 5
matches_df = find_matches(mtDNA_seq, motif, max_mismatch)

print(f"\nНайдено совпадений: {len(matches_df)}")
