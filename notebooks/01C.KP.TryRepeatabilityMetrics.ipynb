def analyze_mutation_patterns(seq, positions):
    """Анализирует паттерны мутаций"""
    patterns = []
    
    for pos in positions:
        ref = seq[pos-1]
        
        start = max(0, pos-4)  # 0-based
        end = min(len(seq), pos+2)  # pos is 1-based, end is exclusive
        context = seq[start:end]
        
        gc_content = (context.count('G') + context.count('C')) / len(context) * 100
        
        for alt in ['A', 'T', 'G', 'C']:
            if alt != ref:
                mut_type = is_synonymous_mutation(seq, pos, ref, alt)
                transition = (ref, alt) in [('A', 'G'), ('G', 'A'), ('C', 'T'), ('T', 'C')]
                
                patterns.append({
                    'position': pos,
                    'ref': ref,
                    'alt': alt,
                    'context': context,
                    'gc_content': gc_content,
                    'transition': transition,
                    'mutation_type': mut_type,
                    'is_transition': transition,
                    'is_transversion': not transition
                })
    
    return pd.DataFrame(patterns)

