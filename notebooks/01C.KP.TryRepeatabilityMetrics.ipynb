    ref_degraded = repeatability_10_degraded_longest_inside_major_arc_pos_not_at_the_edge(pos, ref)
    alt_degraded = repeatability_10_degraded_longest_inside_major_arc_pos_not_at_the_edge(pos, alt)
    
    analysis_results.append({
