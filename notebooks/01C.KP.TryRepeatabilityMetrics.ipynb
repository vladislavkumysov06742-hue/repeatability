    low_gc = patterns_df[patterns_df['gc_content'] < gc_threshold]
    
    if len(high_gc) > 0 and len(low_gc) > 0:
        high_gc_syn = len(high_gc[high_gc['mutation_type'] == 'SYN']) / len(high_gc) * 100
        low_gc_syn = len(low_gc[low_gc['mutation_type'] == 'SYN']) / len(low_gc) * 100
        
        print(f"  GC ≥ {gc_threshold}%: {high_gc_syn:.1f}% SYN (n={len(high_gc)})")
        print(f"  GC < {gc_threshold}%: {low_gc_syn:.1f}% SYN (n={len(low_gc)})")

