        'alt_degraded': alt_degraded,
        'perfect_diff': alt_perfect - ref_perfect if not (pd.isna(alt_perfect) or pd.isna(ref_perfect)) else np.nan,
        'degraded_diff': alt_degraded - ref_degraded if not (pd.isna(alt_degraded) or pd.isna(ref_degraded)) else np.nan,
        'perfect_change': 'INCREASE' if alt_perfect > ref_perfect else 
                         'DECREASE' if alt_perfect < ref_perfect else 
