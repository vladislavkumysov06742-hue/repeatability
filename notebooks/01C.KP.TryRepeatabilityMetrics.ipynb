def generate_all_mutations(positions: list) -> list:
    """Генерирует список всех возможных мутаций для заданных позиций"""
    mutations = []
    
    for pos in positions:
        ref = mtDNA_seq[pos-1].upper()
        if ref not in ['A', 'T', 'G', 'C']:
            continue
        
        gene_info = get_gene_at_position(pos)
        gene_name = gene_info['name'] if gene_info else 'NON-CODING'
        gene_type = gene_info['type'] if gene_info else 'NON-CODING'
        
        for alt in ['A', 'T', 'G', 'C']:
            if alt != ref:
                # Определяем тип мутации
                if gene_type == 'protein_coding':
                    mutation_type = is_synonymous_mutation(mtDNA_seq, pos, ref, alt)
                else:
                    mutation_type = 'NON-CODING'
                
                mutations.append({
                    'position': pos,
                    'ref': ref,
                    'alt': alt,
                    'gene': gene_name,
                    'mutation_type': mutation_type,
                    'is_synonymous': mutation_type == 'SYN',
                    'is_nonsynonymous': mutation_type in ['NON-SYN', 'STOP-GAIN', 'STOP-LOSS']
                })
    
    return pd.DataFrame(mutations)

