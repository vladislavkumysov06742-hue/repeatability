def get_gene_at_position(pos: int) -> dict:
    """Возвращает ген, в котором находится позиция, или None"""
    for gene in mitochondrial_genes:
        if gene['start'] <= pos <= gene['end']:
            return gene
    return None

def get_codon_at_position(seq: str, pos: int, gene_info: dict) -> tuple:
    """
    Возвращает кодон для позиции в гене.
    
    Возвращает: (кодон, позиция_в_кодоне(0,1,2), номер_кодона)
    """
    if gene_info['type'] != 'protein_coding':
        return None, None, None
    
    if gene_info['strand'] == '+':
        gene_pos = pos - gene_info['start'] + 1  # 1-based в гене
    else:  # минус-цепь
        gene_pos = gene_info['end'] - pos + 1
    
    codon_num = (gene_pos + 2) // 3  # Округление вверх
    
    if gene_info['strand'] == '+':
        codon_start = gene_info['start'] + (codon_num - 1) * 3
    else:
        codon_start = gene_info['end'] - (codon_num - 1) * 3 - 2
    
    if gene_info['strand'] == '+':
        codon = seq[codon_start-1:codon_start+2]
    else:
        codon_seq = seq[codon_start-1:codon_start+2]
        codon = str(Seq(codon_seq).reverse_complement())
    
    codon_pos = (gene_pos - 1) % 3
    
    return codon, codon_pos, codon_num

mitochondrial_genetic_code = {
    'ATA': 'I', 'ATC': 'I', 'ATT': 'I', 'ATG': 'M',
    'ACA': 'T', 'ACC': 'T', 'ACG': 'T', 'ACT': 'T',
    'AAC': 'N', 'AAT': 'N', 'AAA': 'K', 'AAG': 'K',
    'AGC': 'S', 'AGT': 'S', 'AGA': '*', 'AGG': '*',
    'CTA': 'L', 'CTC': 'L', 'CTG': 'L', 'CTT': 'L',
    'CCA': 'P', 'CCC': 'P', 'CCG': 'P', 'CCT': 'P',
    'CAC': 'H', 'CAT': 'H', 'CAA': 'Q', 'CAG': 'Q',
    'CGA': 'R', 'CGC': 'R', 'CGG': 'R', 'CGT': 'R',
    'GTA': 'V', 'GTC': 'V', 'GTG': 'V', 'GTT': 'V',
