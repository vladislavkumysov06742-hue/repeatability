    'TTC': 'F', 'TTT': 'F', 'TTA': 'L', 'TTG': 'L',
    'TAC': 'Y', 'TAT': 'Y', 'TAA': '*', 'TAG': '*',
    'TGC': 'C', 'TGT': 'C', 'TGA': 'W', 'TGG': 'W',
}

stop_codons = {'TAA', 'TAG', 'AGA', 'AGG'}

def codon_to_amino_acid(codon: str) -> str:
    """Переводит кодон в аминокислоту (использует митохондриальный генетический код)"""
    return mitochondrial_genetic_code.get(codon.upper(), 'X')  # X для неизвестных кодонов

def is_synonymous_mutation(seq: str, pos: int, ref: str, alt: str) -> str:
    """
    Определяет, является ли мутация синонимичной.
    
    Возвращает:
        'SYN' - синонимичная мутация
        'NON-SYN' - несинонимичная мутация
        'NON-CODING' - мутация вне кодирующей области
        'STOP-GAIN' - появление стоп-кодона
        'STOP-LOSS' - исчезновение стоп-кодона
        'UNKNOWN' - невозможно определить
    """
    if seq[pos-1] != ref:
        return f"ERROR: ref mismatch (expected {seq[pos-1]}, got {ref})"
    
    gene_info = get_gene_at_position(pos)
    if not gene_info:
        return 'NON-CODING'
    
    if gene_info['type'] != 'protein_coding':
        return 'NON-CODING'
    
    original_codon, codon_pos, codon_num = get_codon_at_position(seq, pos, gene_info)
    if original_codon is None:
        return 'UNKNOWN'
    
    mutated_codon = list(original_codon)
    mutated_codon[codon_pos] = alt
    mutated_codon = ''.join(mutated_codon)
    
    original_aa = codon_to_amino_acid(original_codon)
    mutated_aa = codon_to_amino_acid(mutated_codon)
    
    if original_aa == 'X' or mutated_aa == 'X':
        return 'UNKNOWN'
    
    original_is_stop = original_codon in stop_codons
    mutated_is_stop = mutated_codon in stop_codons
    
    if original_is_stop and not mutated_is_stop:
        return 'STOP-LOSS'
    elif not original_is_stop and mutated_is_stop:
        return 'STOP-GAIN'
    elif original_aa == mutated_aa:
        return 'SYN'
    else:
        return 'NON-SYN'

